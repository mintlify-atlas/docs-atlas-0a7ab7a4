  "keyFeatures": [
    "Split architecture with Python brain (FastAPI/LLM) and Rust face (Ratatui TUI)",
    "Real-time token streaming with WebSocket communication",
    "RAG system with ChromaDB for world lore and memory",
    "Session management with SQLite persistence",
    "Multi-provider LLM support (OpenRouter, Groq, DeepSeek, Gemini)",
    "YAML-based asset system for worlds, characters, and rules",
    "Hardcore system rules for grounded, consequence-driven storytelling"
  ],
  "publicApiSurface": [
    "/model <model_id> - Hot-swap LLM model",
    "/world select <world_id> - Select active world",
    "/world attach_lore <text> - Add lore to world",
    "/character select <character_id> - Select active character",
    "/session new - Create new session",
    "/session continue <session_id> - Continue existing session",
    "/session delete <session_id> - Delete session",
    "/rules add <rule_id> - Activate rule",
    "/rules clear - Clear all rules",
    "/nsfw - Toggle NSFW mode",
    "/cancel - Cancel streaming response",
    "WorldManager - Manage world assets",
    "CharacterManager - Manage character assets",
    "SessionManager - Manage roleplay sessions",
    "MessageManager - Manage chat history",
    "RAGManager - Vector storage for lore and memory",
    "stream_chat_response() - Stream LLM responses",
    "handle_command() - Process TUI commands"
  ]
}
